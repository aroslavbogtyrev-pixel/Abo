-- ========== ЛОГИКА ==========

local PlayerActive = false
local NPCActive = false
local WIDTH_OFFSET = 25
local processedPlayers = {}
local processedNPCs = {}

-- Проверка, является ли объект NPC
local function isNPC(character)
    if not character then return false end
    if Players:GetPlayerFromCharacter(character) then return false end
    if not character:FindFirstChildOfClass("Humanoid") then return false end
    return true
end

-- Проверка, широкий ли уже объект
local function isAlreadyWide(part)
    if not part then return false end
    return part.Size.X > 20 or part.Size.Z > 20
end

-- ========== ФУНКЦИЯ БЕЗОПАСНОГО РАСШИРЕНИЯ (без столкновений) ==========

local function widenSafely(character, isNPC)
    if not character then return end
    if character == LocalPlayer.Character then return end
    
    -- Пропускаем уже обработанных
    if isNPC then
        if processedNPCs[character] then return end
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    -- Проверяем, не широкий ли уже
    if isAlreadyWide(rootPart) then return end
    
    -- Расширяем
    rootPart.Size = Vector3.new(
        rootPart.Size.X + WIDTH_OFFSET,
        rootPart.Size.Y,
        rootPart.Size.Z + WIDTH_OFFSET
    )
    
    -- Отключаем CanCollide у ВСЕХ частей этого персонажа
    -- Это главная фишка - ты НЕ будешь биться об них
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
    
    if isNPC then
        processedNPCs[character] = true
        print("✅ Расширен NPC: " .. character.Name)
    else
        local player = Players:GetPlayerFromCharacter(character)
        if player then
            processedPlayers[player] = true
            print("✅ Расширен игрок: " .. character.Name)
        end
    end
end

-- ========== КНОПКА 1: ИГРОКИ ==========

local function processAllPlayers()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            widenSafely(player.Character, false)
        end
    end
end

local function onPlayerAdded(player)
    if not PlayerActive then return end
    if player == LocalPlayer then return end
    
    player.CharacterAdded:Connect(function(character)
        if PlayerActive then
            task.wait(0.5)
            widenSafely(character, false)
        end
    end)
    
    if player.Character then
        task.wait(0.5)
        widenSafely(player.Character, false)
    end
end

local function onPlayerCharacterAdded(character)
    if not PlayerActive then return end
    local player = Players:GetPlayerFromCharacter(character)
    if not player or player == LocalPlayer then return end
    task.wait(0.5)
    widenSafely(character, false)
end

local function activatePlayerMode()
    PlayerActive = true
    PlayerBtn.Text = "✅ ИГРОКИ"
    PlayerBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    print("👤 Режим ИГРОКОВ активирован (+" .. WIDTH_OFFSET .. ")")
    
    processAllPlayers()
    
    Players.PlayerAdded:Connect(onPlayerAdded)
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            player.CharacterAdded:Connect(onPlayerCharacterAdded)
        end
    end
end

local function deactivatePlayerMode()
    PlayerActive = false
    PlayerBtn.Text = "1️⃣ ИГРОКИ"
    PlayerBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 150)
    print("👤 Режим ИГРОКОВ деактивирован")
end

-- ========== КНОПКА 2: NPC ==========

local function findAllNPCs()
    local npcs = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and isNPC(obj) then
            table.insert(npcs, obj)
        end
    end
    return npcs
end

local function processAllNPCs()
    local npcs = findAllNPCs()
    for _, npc in ipairs(npcs) do
        widenSafely(npc, true)
    end
    print("🤖 Найдено NPC: " .. #npcs)
end

local function watchForNewNPCs()
    workspace.DescendantAdded:Connect(function(obj)
        if not NPCActive then return end
        task.wait(0.5)
        if obj:IsA("Model") and isNPC(obj) then
            widenSafely(obj, true)
        end
    end)
end

local function activateNPCMode()
    NPCActive = true
    NPCBtn.Text = "✅ NPC"
    NPCBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    print("🤖 Режим NPC активирован (+" .. WIDTH_OFFSET .. ")")
    print("🛡️ Столкновения с NPC отключены!")
    
    processAllNPCs()
    watchForNewNPCs()
end

local function deactivateNPCMode()
    NPCActive = false
    NPCBtn.Text = "2️⃣ NPC"
    NPCBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 200)
    print("🤖 Режим NPC деактивирован")
end

